# Copy this file to `.env.local` (which is gitignored) and fill in the value.
# Only variables prefixed with VITE_ are exposed to the app (Vite convention).

# Google Picker API key — the "browse your real Drive" folder chooser.
# Get/rotate it in Google Cloud Console (project 526107030062):
#   APIs & Services -> Credentials -> your Picker API key.
# Restrict it to the Google Picker API + http://localhost:5173/* .
# Leave blank to run in Sample mode only.
VITE_PICKER_API_KEY=
